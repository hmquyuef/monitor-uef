# ============================================================
# Monitor-UEF — Biến Môi Trường Chung (Root)
# Copy file này thành .env và điền các giá trị thực
# ============================================================

# --- Database ---
DB_NAME=monitor_uef
DB_USER=postgres
DB_PASSWORD=changeme_strong_password
DB_HOST=localhost
DB_PORT=5432

# --- Server ---
SERVER_PORT=3000
NODE_ENV=production
ADMIN_API_KEY=change-this-to-a-secret-key

# --- Agent (used by monitor-agent container) ---
API_KEY=agent-secret-key-01
AGENT_NAME=local-server
COLLECT_INTERVAL=10

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_COOLDOWN_MINUTES=5

# --- PgAdmin ---
PGADMIN_EMAIL=admin@monitor.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# --- Agent Offline Timeout ---
AGENT_OFFLINE_TIMEOUT=120
